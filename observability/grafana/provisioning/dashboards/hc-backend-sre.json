      "title": "Presupuesto de error restante (barra)",
      "type": "bargauge",
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(http_requests_total{app=\"hc-backend\",status_code=~\"5..\"}[$__range])) / clamp_min(sum(rate(http_requests_total{app=\"hc-backend\"}[$__range])), 0.001)) / 0.005)",
          "legendFormat": "restante"
        }
      ]
