  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Cumplimiento del SLO de disponibilidad (peticiones sin 5xx) en la ventana visible. Meta: 99.5%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 2,
          "min": 90,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "title": "SLO Disponibilidad (meta 99.5%)",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{app=\"hc-backend\",status_code!~\"5..\"}[$__range])) / clamp_min(sum(rate(http_requests_total{app=\"hc-backend\"}[$__range])), 0.001)",
          "legendFormat": "disponibilidad"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Presupuesto de error restante = 100% x (1 - fraccion_5xx / 0.005). SLO 99.5% => budget 0.5% (201.6 min / 28 dias).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "title": "Error budget restante",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * (1 - (sum(rate(http_requests_total{app=\"hc-backend\",status_code=~\"5..\"}[$__range])) / clamp_min(sum(rate(http_requests_total{app=\"hc-backend\"}[$__range])), 0.001)) / 0.005)",
          "legendFormat": "restante"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Porcentaje de peticiones servidas en menos de 500 ms (bucket le=0.5). Meta: 95%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 2,
          "min": 80,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "title": "SLO Latencia (< 500 ms, meta 95%)",
      "type": "stat",
      "targets": [
        {
          "expr": "100 * sum(rate(http_request_duration_seconds_bucket{app=\"hc-backend\",le=\"0.5\"}[$__range])) / clamp_min(sum(rate(http_request_duration_seconds_count{app=\"hc-backend\"}[$__range])), 0.001)",
          "legendFormat": "% < 500ms"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Latencia P95 instantanea (ventana 5m). Umbral de SLO: 0.5 s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "title": "P95 Latencia (SLI)",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"hc-backend\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Percentiles de latencia. La linea de umbral marca el SLO de 500 ms.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "title": "Latencia P50 / P95 / P99 (umbral SLO 500 ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app=\"hc-backend\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"hc-backend\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app=\"hc-backend\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Tasa de quema del presupuesto de error (fraccion_5xx / 0.005). >1 consume mas rapido de lo permitido. 6x => TICKET, 14.4x => PAGE.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": { "mode": "single" }
      },
      "title": "Burn-rate del presupuesto de error (5xx)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{app=\"hc-backend\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{app=\"hc-backend\"}[5m])), 0.001)) / 0.005",
          "legendFormat": "burn-rate x"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Trafico por ruta y metodo. La ruta critica es POST /:id/odontograma.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Requests por segundo (por ruta)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{app=\"hc-backend\"}[1m])) by (route, method)",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Presupuesto de error consumido vs restante en la ventana visible.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
