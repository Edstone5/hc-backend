{
  "name": "hc-backend",
  "version": "2.1.0",
  "description": "Backend del Sistema de Historia Clínica UNJBG — Arquitectura Hexagonal, Node.js/Express, MySQL",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:cov": "vitest run --coverage --config vitest.coverage.config.js",
    "test:bdd": "cucumber-js",
    "test:mutation": "stryker run",
    "dev": "dotenv -e .env.local -- node --watch api.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "start": "node --import ./tracing.js api.js",
    "start:notrace": "node api.js",
    "start:prod": "NODE_ENV=production node --import ./tracing.js api.js",
    "db:init": "mysql -h $DB_HOST -u $DB_USER -p$DB_PASSWORD $DB_NAME < db/init.sql",
    "db:migrate": "node db/migrate.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Edstone5/hc-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Edstone5/hc-backend/issues"
  },
  "homepage": "https://github.com/Edstone5/hc-backend#readme",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@supabase/supabase-js": "^2.106.2",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^10.0.0",
    "express": "5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.22.4",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@cucumber/cucumber": "^12.9.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^4.0.15",
    "c8": "^10.1.3",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "vitest": "^4.0.15"
  }
}
