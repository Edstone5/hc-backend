# ── Base de datos (lo que realmente lee la app: db/db.js usa DATABASE_URL) ──────
# PostgreSQL / NeonDB (recomendado). Pídela al equipo o usa la tuya.
#   postgresql://USUARIO:PASSWORD@HOST.neon.tech/BASEDATOS?sslmode=require
# También soporta MySQL:  mysql://USUARIO:PASSWORD@HOST:3306/BASEDATOS
DATABASE_URL=postgresql://hc_user:hc_password@localhost:5432/hc_db?sslmode=disable

# ── JWT ────────────────────────────────────────────────────────────────────────
# Genera valores seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_valor_seguro
JWT_REFRESH_SECRET=cambia_esto_por_un_valor_seguro_diferente

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── (Opcional) Docker Compose con MySQL ─────────────────────────────────────────
# Solo si levantas la BD con docker-compose / scripts db:init (mysql CLI).
# El runtime de la app NO lee estas variables; usa DATABASE_URL de arriba.
#   DB_HOST=mysql        # nombre del servicio en Compose (o localhost en local)
#   DB_USER=hc_user
#   DB_PASSWORD=hc_password
#   DB_NAME=hc_db
#   DB_PORT=3306
