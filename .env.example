# ── MySQL ─────────────────────────────────────────────────────────────────────
# Con Docker Compose: DB_HOST=mysql (nombre del servicio)
# Local:             DB_HOST=localhost
DB_HOST=localhost
DB_USER=hc_user
DB_PASSWORD=hc_password
DB_NAME=hc_db
DB_PORT=3306

# ── JWT ────────────────────────────────────────────────────────────────────────
# Genera valores seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_valor_seguro
JWT_REFRESH_SECRET=cambia_esto_por_un_valor_seguro_diferente

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
